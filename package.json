{
  "name": "capcut-tts",
  "description": "CapCut TTS API を扱いやすくする Express ベースのラッパープロキシ",
  "version": "2.0.0",
  "author": "",
  "keywords": [
    "typescript",
    "expressjs",
    "capcut",
    "tts",
    "proxy"
  ],
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "capcut:extract": "tsx src/scripts/extractCapCutBundles.ts",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "lint:fix": "npm run lint -- --fix",
    "wintest": "title %npm_config_id% && npm run build && node ./dist/index.js",
    "test": "npm run build && node ./dist/index.js",
    "winstart": "title %npm_config_id% && node ./dist/index.js",
    "start": "node ./dist/index.js"
  },
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "tslog": "^4.10.2",
    "ws": "^8.14.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.15",
    "@types/ws": "^8.5.6",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
