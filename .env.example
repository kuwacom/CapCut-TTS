# CapCut Web Endpoint
CAPCUT_WEB_URL=https://www.capcut.com
CAPCUT_EDIT_API_URL=https://edit-api-sg.capcut.com
CAPCUT_LOGIN_HOST=https://login-row.www.capcut.com
CAPCUT_FALLBACK_LOGIN_HOST=https://login.us.capcut.com

# CapCut Account
CAPCUT_EMAIL=
CAPCUT_PASSWORD=

# Locale / Device
CAPCUT_LOCALE=ja-JP
CAPCUT_PAGE_LOCALE=ja-jp
CAPCUT_REGION=JP
CAPCUT_STORE_COUNTRY_CODE=jp
# CAPCUT_DEVICE_ID=
# CAPCUT_TDID=
# CAPCUT_VERIFY_FP=

# Bundle config cache
# CapCut の bundle から動的抽出した設定を保存するファイル
# 通常運用では HAR は必須ではなく、このキャッシュがあれば毎回 live 取得しなくてよい
# 必要に応じて `npm run capcut:extract` で HAR から事前生成も可能
CAPCUT_BUNDLE_CONFIG_PATH=capcut-bundle-config.json

# Default fallback category id
# 実際の運用では bundle から抽出した category ids を優先して使用する
CAPCUT_VOICE_CATEGORY_ID=21699

# Session cache
CAPCUT_SESSION_STORE_PATH=capcut-session.json
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36

# Node Setting
LOG_LEVEL=info
ERROR_HANDLE=true

# Server Setting
HOST=0.0.0.0
PORT=8080

# Preferred CORS key used by the latest Expressjs-Template layout.
CORS_POLICY_ORIGIN=*

# Legacy fallback is still supported for existing deployments.
# ORIGIN=*

# Background session validation interval (minutes)
SESSION_REFRESH_INTERVAL_MINUTES=10

# Legacy TTS Endpoint (/v1/legacy)
LEGACY_CAPCUT_API_URL=https://edit-api-sg.capcut.com/lv/v1
LEGACY_BYTEINTL_API_URL=wss://sami-sg1.byteintlapi.com/internal/api/v1
# LEGACY_DEVICE_TIME=
# LEGACY_SIGN=
LEGACY_TOKEN_INTERVAL=6
